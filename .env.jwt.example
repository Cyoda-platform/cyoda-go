# Profile: jwt — JWT authentication mode.
# Copy to .env.jwt and customize.
# Usage: CYODA_PROFILES=jwt go run ./cmd/cyoda
#
# The signing key should be set via shell env (not committed):
#   CYODA_JWT_SIGNING_KEY="$(cat signing.pem)" CYODA_PROFILES=jwt go run ./cmd/cyoda

CYODA_IAM_MODE=jwt
CYODA_JWT_ISSUER=cyoda-go
CYODA_JWT_EXPIRY_SECONDS=3600
CYODA_BOOTSTRAP_CLIENT_ID=m2m.user
CYODA_BOOTSTRAP_TENANT_ID=default-tenant
CYODA_BOOTSTRAP_ROLES=ROLE_ADMIN,ROLE_M2M
